// ========== Generic Tool Helpers ==========

// ========== Helper Functions ==========

/// Parse an enum parameter from arguments with validation
fn parse_enum_param<T>(args: &Map<String, Value>, field: &str) -> Result<Option<T>>
where
    T: for<'de> serde::Deserialize<'de> + fmt::Display,
{
    match args.get(field) {
        Some(Value::String(s)) => {
            // Parse using serde's string deserializer
            let value: T = serde_json::from_value(Value::String(s.clone()))
                .map_err(|_| anyhow!("Invalid value for {}: '{}'. Expected a valid enum value.", field, s))?;
            Ok(Some(value))
        }
        Some(_) => Err(anyhow!("{} must be a string", field)),
        None => Ok(None),
    }
}

// ========== Generic API Handlers ==========

/// Generic POST handler - creates or updates a resource
async fn api_post(
    server: &Server,
    endpoint: &str,
    args: Map<String, Value>,
) -> Result<Value> {
    server.api.post(endpoint, Value::Object(args)).await
}

/// Generic PUT handler - updates a resource
async fn api_put(
    server: &Server,
    endpoint: &str,
    args: Map<String, Value>,
) -> Result<Value> {
    server.api.put(endpoint, Value::Object(args)).await
}

/// Generic GET by ID handler
async fn api_get_by_id(
    server: &Server,
    endpoint_template: &str,  // e.g., "/api/tasks/{}"
    id_field: &str,            // e.g., "task_id"
    args: &Map<String, Value>,
) -> Result<Value> {
    let id = args
        .get(id_field)
        .and_then(|v| v.as_str())
        .ok_or_else(|| anyhow!("Missing required parameter: {}", id_field))?;

    server.api.get(&endpoint_template.replace("{}", id), None).await
}

/// Generic GET with query filters
async fn api_get_with_filters(
    server: &Server,
    endpoint: &str,
    required_fields: &[&str],
    optional_fields: &[&str],
    args: &Map<String, Value>,
) -> Result<Value> {
    let mut query = Vec::new();

    // Add required query parameters
    for &field in required_fields {
        let value = args
            .get(field)
            .and_then(|v| v.as_str())
            .ok_or_else(|| anyhow!("Missing required parameter: {}", field))?;
        query.push((field.to_string(), value.to_string()));
    }

    // Add optional string parameters
    for &field in optional_fields {
        if let Some(value) = args.get(field).and_then(|v| v.as_str()) {
            query.push((field.to_string(), value.to_string()));
        }
    }

    // Add optional boolean parameters (e.g., include_plan_context)
    for &field in optional_fields {
        if let Some(value) = args.get(field).and_then(|v| v.as_bool()) {
            query.push((field.to_string(), value.to_string()));
        }
    }

    server.api.get(endpoint, Some(query)).await
}

/// Generic DELETE handler
async fn api_delete(
    server: &Server,
    endpoint_template: &str,  // e.g., "/api/tasks/{}/dependencies/{}"
    id_fields: &[&str],        // e.g., ["task_id", "depends_on"]
    args: &Map<String, Value>,
) -> Result<Value> {
    let mut endpoint = endpoint_template.to_string();

    for &field in id_fields {
        let value = args
            .get(field)
            .and_then(|v| v.as_str())
            .ok_or_else(|| anyhow!("Missing required parameter: {}", field))?;

        // Replace first occurrence of {}
        endpoint = endpoint.replacen("{}", value, 1);
    }

    server.api.delete(&endpoint).await
}

/// Route tool calls to implementations
pub async fn call_tool(
    server: &mut Server,
    name: &str,
    args: Map<String, Value>,
) -> Result<Value> {
    match name {
        "load_session_state" => load_session_state(server, args).await,
        "save_session_state" => save_session_state(server, args).await,
        "get_tasks" => get_tasks(server, args).await,
        "get_task" => get_task(server, args).await,
        "save_task" => save_task(server, args).await,
        "update_task_status" => update_task_status(server, args).await,
        "update_task" => update_task(server, args).await,
        "add_task_dependency" => add_task_dependency(server, args).await,
        "remove_task_dependency" => remove_task_dependency(server, args).await,
        "add_progress_log" => add_progress_log(server, args).await,
        "save_document" => save_document(server, args).await,
        "get_documents" => get_documents(server, args).await,
        "get_document" => get_document(server, args).await,
        "update_document" => update_document(server, args).await,
        "link_document" => link_document(server, args).await,
        "save_plan" => save_plan(server, args).await,
        "get_plans" => get_plans(server, args).await,
        "save_decision" => save_decision(server, args).await,
        "get_decisions" => get_decisions(server, args).await,
        // AST Tools
        "parse_file_ast" => parse_file_ast(server, args).await,
        "analyze_concurrency" => analyze_concurrency_tool(args).await,
        "analyze_react_component" => analyze_react_component_tool(args).await,
        "find_interface_implementations" => find_interface_implementations_tool(args).await,
        // Engine V2 Intelligence Tools
        "search_code_context" => search_code_context(server, args).await,
        "read_symbol_lines" => read_symbol_lines(args).await,
        "query_context" => query_context(server, args).await,
        "query_graph" => query_graph(server, args).await,
        "get_graph_neighbors" => get_graph_neighbors(server, args).await,
        _ => Err(anyhow!("Unknown tool: {}", name)),
    }
}

